<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#1565C0" id="metaThemeColor">
    <link rel="manifest" href="manifest.json">
    <link rel="icon" href="icon.png">
    <link rel="apple-touch-icon" href="icon.png">
    <title>Gestor de Compras</title>

    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; background-color: #f0f2f5; margin: 0; padding: 0; display: flex; justify-content: center; user-select: none; -webkit-user-select: none; -webkit-touch-callout: none; overflow: hidden; }
        input, select, textarea { user-select: auto; -webkit-user-select: auto; font-family: inherit; }
        .app-container { width: 100%; max-width: 100%; background-color: #ffffff; height: 100vh; display: flex; flex-direction: column; position: relative; overflow: hidden; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
        
        #splashScreen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: #1565C0; z-index: 9999; display: flex; flex-direction: column; align-items: center; justify-content: center; color: white; transition: opacity 0.5s ease; }
        .splash-titulo { font-size: 32px; font-weight: bold; }

        .header { padding: 15px; display: flex; justify-content: space-between; align-items: center; color: white; transition: background-color 0.3s; }
        .header-select { background: transparent; color: white; border: none; font-size: 20px; font-weight: bold; outline: none; padding-right: 5px; -webkit-appearance: none; appearance: none; }
        .header-select option { color: black; font-size: 16px; }
        .header-actions button { background: none; border: none; color: white; font-size: 24px; cursor: pointer; }
        
        body.theme-pedido .header { background-color: #1565C0 !important; }
        body.theme-compras .header { background-color: #6a1b9a !important; }

        .area-conteudo { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .scroll-area { overflow-y: auto; flex: 1; min-height: 0; padding-bottom: 20px; }

        .filters { padding: 10px 15px; display: flex; gap: 10px; overflow-x: auto; white-space: nowrap; border-bottom: 1px solid #eee; background: white; flex-shrink: 0; }
        .chip { background-color: #e0e0e0; color: #333; padding: 8px 16px; border-radius: 20px; cursor: pointer; font-size: 14px; font-weight: bold; border: 2px solid transparent; }
        .chip.active { border-color: #333; opacity: 0.9; }

        .list { padding: 0; margin: 0; list-style: none; }
        .item { display: flex; align-items: center; padding: 12px 15px; border-bottom: 1px solid #eee; transition: transform 0.2s, background-color 0.2s; position: relative; }
        .item-avatar { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-right: 15px; flex-shrink: 0; color: white; }
        .item-info { flex: 1; pointer-events: none; }
        .item-title { font-weight: bold; font-size: 17px; margin-bottom: 2px; }
        .item-subtitle { color: #666; font-size: 13px; line-height: 1.4; }
        
        .item.riscado { opacity: 0.6; }
        .item.riscado .item-title { text-decoration: line-through; }
        
        .status-pedido { border-left: 8px solid #9c27b0; background-color: #f3e5f5; }
        .status-comprado { border-left: 8px solid #81c784; background-color: #e8f5e9; }
        .status-entregue { border-left: 8px solid #4caf50; background-color: #c8e6c9; }
        
        .swipe-hint { color: #888; font-size: 12px; pointer-events: none; text-align: right; }

        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); align-items: center; justify-content: center; z-index: 1000; }
        .modal { background: white; padding: 20px; border-radius: 10px; width: 90%; max-width: 450px; max-height: 90vh; overflow-y: auto; box-shadow: 0 5px 20px rgba(0,0,0,0.3); }
        .modal-title { font-size: 20px; font-weight: bold; margin-bottom: 20px; color: #333; border-bottom: 2px solid; padding-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
        
        body.theme-pedido .modal-title { border-color: #1565C0; }
        body.theme-compras .modal-title { border-color: #6a1b9a; }

        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; color: #555; font-weight: bold; font-size: 13px; }
        .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px; box-sizing: border-box; font-size: 15px; }
        
        .modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; flex-wrap: wrap; }
        .btn-cancel { background: #eee; border: none; padding: 12px 20px; border-radius: 5px; cursor: pointer; color: #333; font-weight: bold; flex: 1; text-align: center; }
        .btn-action { border: none; padding: 12px 20px; border-radius: 5px; cursor: pointer; color: white; font-weight: bold; flex: 1; text-align: center; }
        .btn-outline { background: transparent; border: 1px solid #333; padding: 12px; border-radius: 5px; cursor: pointer; font-weight: bold; width: 100%; margin-bottom: 10px; text-align: left; }
        
        body.theme-pedido .btn-action { background: #1565C0; }
        body.theme-compras .btn-action { background: #6a1b9a; }

        .btn-zap { background: #25d366 !important; color: white; }
        
        .fab { position: fixed; bottom: 20px; right: 20px; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); z-index: 90; cursor: pointer; color: white; }
        body.theme-compras .fab { background-color: #25d366; }
    </style>
</head>
<body class="theme-pedido" oncontextmenu="return false;">

<div id="splashScreen">
    <div class="splash-titulo">Gestor Compras</div>
    <div style="font-size: 16px; opacity: 0.8; margin-top: 5px;">v2.0 Pro</div>
</div>

<div class="app-container">
    <div class="header" id="mainHeader">
        <select class="header-select" id="seletorModo" onchange="alterarModo(this.value)">
            <option value="pedido">📝 Modo Pedido</option>
            <option value="compras">🛒 Modo Compras</option>
        </select>
        <div class="header-actions">
            <button onclick="abrirAdmin()">⚙️</button>
        </div>
    </div>

    <div class="area-conteudo">
        <div class="filters" id="containerFiltros"></div>
        <div class="scroll-area">
            <ul class="list" id="listaPrincipal"></ul>
        </div>
    </div>

    <div id="fabZap" class="fab" style="display: none;" onclick="abrirModalZap()">📱</div>
</div>

<div class="modal-overlay" id="modalSenhaAdmin">
    <div class="modal">
        <div class="modal-title">Acesso Restrito</div>
        <div class="form-group">
            <label>Senha de Administração:</label>
            <input type="password" id="inputSenhaAdmin" placeholder="Digite a senha" inputmode="numeric" pattern="[0-9]*" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
        </div>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="fecharModal('modalSenhaAdmin')">Cancelar</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modalPainelUnificado">
    <div class="modal">
        <div class="modal-title">Configurações Gerais</div>
        
        <button class="btn-outline" onclick="abrirCadastroRestaurante()">🏢 Dados do Restaurante</button>
        <button class="btn-outline" onclick="abrirCadastroProduto()">🍔 Cadastrar Produto Rápido</button>
        <button class="btn-outline" onclick="abrirCadastroColaborador()">👥 Cadastrar Colaborador</button>
        <button class="btn-outline" onclick="abrirCadastroFornecedor()">🚚 Cadastrar Fornecedor</button>
        
        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <div class="form-group">
            <label style="color: #1565C0;">URL do Google Script (Nuvem):</label>
            <input type="text" id="inputGoogleUrl" placeholder="https://script.google.com/macros/s/...">
            <button class="btn-action" style="margin-top: 8px;" onclick="salvarConfigURL()">💾 Salvar URL</button>
        </div>
        
        <div style="display: flex; gap: 10px; margin-top: 15px;">
            <button id="btnPuxarNuvem" class="btn-cancel" style="background: #e3f2fd; color: #1565C0;" onclick="puxarDaNuvem()">⬇️ Puxar</button>
            <button id="btnSalvarNuvem" class="btn-outline" style="margin: 0; border-color: #2e7d32; color: #2e7d32;" onclick="salvarNaNuvem()">⬆️ Salvar</button>
        </div>

        <div class="modal-actions">
            <button class="btn-cancel" onclick="fecharModal('modalPainelUnificado')">Fechar Painel</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modalFazerPedido">
    <div class="modal">
        <div class="modal-title" id="pedidoTitulo">Selecionar Item</div>
        <input type="hidden" id="pedidoIdProduto">
        <div class="form-group">
            <label>Quantidade e Unidade:</label>
            <div style="display: flex; gap: 10px;">
                <input type="number" id="pedidoQtd" style="flex: 2;" step="0.01">
                <input type="text" id="pedidoUnidade" readonly style="flex: 1; background: #eee; text-align: center;">
            </div>
        </div>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="fecharModal('modalFazerPedido')">Cancelar</button>
            <button class="btn-action" onclick="confirmarInclusaoPedido()">Adicionar à Lista</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modalZap">
    <div class="modal">
        <div class="modal-title" style="border-color:#25d366;">Gerar Relatório</div>
        <div class="form-group">
            <label>Colaborador Responsável:</label>
            <select id="zapColaborador"></select>
        </div>
        <div class="form-group">
            <label>Filtrar por Fornecedor:</label>
            <select id="zapFornecedor" onchange="gerarTextoZap()"></select>
        </div>
        <div class="form-group">
            <label>Preview do Pedido:</label>
            <textarea id="zapTexto" rows="10" readonly style="font-size: 13px; background: #f9f9f9;"></textarea>
        </div>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="fecharModal('modalZap')">Voltar</button>
            <button class="btn-action btn-zap" onclick="copiarZap()">Copiar Texto</button>
        </div>
    </div>
</div>

<script>
    let db = carregarBanco();
    let categoriaAtual = null;

    function carregarBanco() {
        let base = {
            restaurante: { nome: "Meu Restaurante", cnpj: "00.000.000/0001-00", endereco: "Rua Exemplo, 123", bairro: "Centro", cidade: "Sua Cidade", ponto: "Próximo à praça" },
            categorias: [{ id: "c1", nome: "Carnes", cor: "#d32f2f", corTexto: "#fff" }, { id: "c2", nome: "Hortifruti", cor: "#388e3c", corTexto: "#fff" }],
            fornecedores: [{ id: "f1", nome: "Frigorífico Bom Boi" }, { id: "f2", nome: "Hortifruti da Esquina" }],
            colaboradores: [{ id: "col1", nome: "Henrique", senha: "123", telefone: "83 99999-9999" }],
            produtos: [
                { id: "p1", nome: "Carne Moída Patinho", categoria: "Carnes", marcasAprovadas: "Friboi, Seara", marcasReprovadas: "Marca X", historicoPrecos: [{ data: "2026-03-07", preco: 35.50 }], qtdPadrao: 5, unidade: "kg", fornecedores: ["f1"] },
                { id: "p2", nome: "Tomate Carmem", categoria: "Hortifruti", marcasAprovadas: "Qualquer", marcasReprovadas: "", historicoPrecos: [{ data: "2026-03-07", preco: 8.00 }], qtdPadrao: 2, unidade: "cx", fornecedores: ["f2"] }
            ],
            pedidosAtivos: [], 
            configs: { modo: "pedido", senhaAdmin: "1999", url: "", dadosBaixados: false }
        };
        let salvo = localStorage.getItem('gestor_compras_v2');
        return salvo ? JSON.parse(salvo) : base;
    }

    function salvarBanco() { localStorage.setItem('gestor_compras_v2', JSON.stringify(db)); }
    function getHojeSTR() { const d = new Date(); return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; }

    function salvarConfigURL() {
        const inputUrl = document.getElementById('inputGoogleUrl').value.trim();
        if(!inputUrl) return alert("Digite a URL gerada pelo Google Apps Script!");
        db.configs.url = inputUrl; salvarBanco(); alert("URL Salva! Tentando puxar dados da nuvem..."); puxarDaNuvem(false);
    }

    async function salvarNaNuvem() {
        if(!db.configs.url) return alert("Configure a URL do Google Script primeiro!");
        if(!db.configs.dadosBaixados) { if(!confirm("⚠️ ATENÇÃO: Você ainda não puxou os dados da nuvem neste dispositivo. Salvar agora pode apagar o que está na nuvem. Deseja forçar o salvamento?")) return; }
        try {
            const btn = document.getElementById('btnSalvarNuvem'); if(btn) btn.innerText = "Salvando...";
            await fetch(db.configs.url, { method: 'POST', mode: 'no-cors', body: JSON.stringify({ action: 'salvar_banco', dados: db }) });
            db.configs.dadosBaixados = true; salvarBanco(); alert("Sincronização enviada para a nuvem!"); if(btn) btn.innerText = "⬆️ Salvar";
        } catch(e) { alert("Erro de conexão ao salvar na nuvem."); const btn = document.getElementById('btnSalvarNuvem'); if(btn) btn.innerText = "⬆️ Salvar"; }
    }

    async function puxarDaNuvem(pedirConfirmacao = true) {
        if(!db.configs.url) return;
        if(pedirConfirmacao && !confirm("Puxar os dados vai substituir tudo o que está na tela. Continuar?")) return;
        try {
            const btn = document.getElementById('btnPuxarNuvem'); if(btn) btn.innerText = "Puxando...";
            let res = await fetch(db.configs.url); let nuvemDB = await res.json();
            if(nuvemDB && nuvemDB.produtos) {
                let modoAtual = db.configs.modo; db = nuvemDB; db.configs.modo = modoAtual; db.configs.dadosBaixados = true; salvarBanco();
                if(pedirConfirmacao) { alert("Sucesso! Banco atualizado."); location.reload(); } else { alterarModo(db.configs.modo, true); }
            } else { alert("A nuvem está vazia. Salve seus dados nela primeiro."); }
            if(btn) btn.innerText = "⬇️ Puxar";
        } catch(e) { alert("Erro ao conectar com a nuvem."); const btn = document.getElementById('btnPuxarNuvem'); if(btn) btn.innerText = "⬇️ Puxar"; }
    }

    window.onload = () => {
        if (!sessionStorage.getItem('splash_shown')) {
            setTimeout(() => { const splash = document.getElementById('splashScreen'); splash.style.opacity = '0'; setTimeout(() => { splash.style.display = 'none'; sessionStorage.setItem('splash_shown', 'true'); }, 500); }, 2000);
        } else { document.getElementById('splashScreen').style.display = 'none'; }
        document.getElementById('seletorModo').value = db.configs.modo; alterarModo(db.configs.modo, true);
    };

    function alterarModo(modo, inicio = false) {
        db.configs.modo = modo; document.body.className = `theme-${modo}`; document.getElementById('metaThemeColor').content = modo === 'pedido' ? '#1565C0' : '#6a1b9a'; document.getElementById('fabZap').style.display = modo === 'compras' ? 'flex' : 'none';
        if(!inicio) salvarBanco(); renderizarFiltros(); renderizarLista();
    }

    function renderizarFiltros() {
        let html = `<div class="chip ${categoriaAtual === null ? 'active' : ''}" style="${categoriaAtual === null ? 'background:#ccc; color:#000;' : ''}" onclick="filtrarCat(null)">TODOS</div>`;
        db.categorias.forEach(cat => { const isActive = categoriaAtual === cat.nome; html += `<div class="chip ${isActive ? 'active' : ''}" style="background-color: ${cat.cor}; color: ${cat.corTexto};" onclick="filtrarCat('${cat.nome}')">${cat.nome}</div>`; });
        document.getElementById('containerFiltros').innerHTML = html;
    }

    function filtrarCat(catNome) { categoriaAtual = catNome; renderizarFiltros(); renderizarLista(); }

    function renderizarLista() {
        const lista = document.getElementById('listaPrincipal'); lista.innerHTML = ''; let itensMostrados = 0;
        if (db.configs.modo === 'pedido') {
            let produtosFiltrados = categoriaAtual === null ? db.produtos : db.produtos.filter(p => p.categoria === categoriaAtual);
            produtosFiltrados.forEach(p => {
                const catObj = db.categorias.find(c => c.nome === p.categoria) || { cor: '#999', corTexto: '#fff' };
                const pedidoAtivo = db.pedidosAtivos.find(pa => pa.produtoId === p.id && pa.status !== 'entregue');
                let classesExtra = ""; let subtitulo = `Padrão: ${p.qtdPadrao} ${p.unidade} | Último R$: ${p.historicoPrecos.length > 0 ? p.historicoPrecos[p.historicoPrecos.length-1].preco.toFixed(2) : '0.00'}`;
                let acao = `onclick="abrirModalPedirProduto('${p.id}')"`; let hint = "Tocar p/ Pedir";
                if (pedidoAtivo) {
                    if (pedidoAtivo.riscado) { classesExtra = "riscado"; hint = "👈 Swipe: Desriscar"; } else { classesExtra = "status-pedido"; hint = "👈 Swipe: Riscar | Toque 2x: Excluir"; }
                    subtitulo = `Na lista: <b>${pedidoAtivo.qtd} ${p.unidade}</b>`; acao = ""; 
                }
                lista.innerHTML += `<li class="item ${classesExtra}" data-id="${pedidoAtivo ? pedidoAtivo.idUnico : ''}" data-tipo="catalogo" ${acao} ontouchstart="handleTouchStart(event, this)" ontouchmove="handleTouchMove(event)" ontouchend="handleTouchEnd(event, this)"><div class="item-avatar" style="background-color: ${catObj.cor}; color: ${catObj.corTexto};">${p.nome.charAt(0)}</div><div class="item-info"><div class="item-title">${p.nome}</div><div class="item-subtitle">${subtitulo}</div></div><div class="swipe-hint">${hint}</div></li>`;
                itensMostrados++;
            });
        } else {
            let pedidos = db.pedidosAtivos.filter(pa => pa.status !== 'entregue' && !pa.riscado);
            pedidos.forEach(pa => {
                const p = db.produtos.find(prod => prod.id === pa.produtoId); if(!p) return; if(categoriaAtual !== null && p.categoria !== categoriaAtual) return;
                const catObj = db.categorias.find(c => c.nome === p.categoria) || { cor: '#999', corTexto: '#fff' };
                lista.innerHTML += `<li class="item status-${pa.status}" data-id="${pa.idUnico}" data-tipo="pedido" ontouchstart="handleTouchStart(event, this)" ontouchmove="handleTouchMove(event)" ontouchend="handleTouchEnd(event, this)"><div class="item-avatar" style="background-color: ${catObj.cor}; color: ${catObj.corTexto};">${p.nome.charAt(0)}</div><div class="item-info"><div class="item-title">${p.nome} - ${pa.qtd} ${p.unidade}</div><div class="item-subtitle">Marcas OK: ${p.marcasAprovadas || 'N/A'}<br>Evitar: ${p.marcasReprovadas || 'Nenhuma'}<br><b style="text-transform: uppercase;">Status: ${pa.status}</b></div></div><div class="swipe-hint" style="text-align:right;">👈 Swipe: Mudar Status<br>Toque 2x: Excluir</div></li>`;
                itensMostrados++;
            });
        }
        if(itensMostrados === 0) { lista.innerHTML = `<li style="padding: 20px; text-align: center; color: #999;">Nenhum item encontrado.</li>`; }
    }

    let touchStartX = 0; let pressTimer; let isLongPress = false; let lastTap = 0; let tapTimer;
    function handleTouchStart(e, elemento) { touchStartX = e.changedTouches[0].screenX; isLongPress = false; pressTimer = setTimeout(() => { isLongPress = true; }, 600); }
    function handleTouchMove(e) { clearTimeout(pressTimer); }
    function handleTouchEnd(e, elemento) { 
        clearTimeout(pressTimer); if(isLongPress) return;
        let diffX = e.changedTouches[0].screenX - touchStartX; let idItem = elemento.getAttribute('data-id'); let tipo = elemento.getAttribute('data-tipo');
        if(!idItem) return;
        if (Math.abs(diffX) < 20) {
            let currentTime = new Date().getTime(); let tapLength = currentTime - lastTap;
            if (tapLength < 350 && tapLength > 0) { clearTimeout(tapTimer); if(confirm("Excluir item do pedido?")) { db.pedidosAtivos = db.pedidosAtivos.filter(pa => pa.idUnico !== idItem); salvarBanco(); renderizarLista(); } } else { tapTimer = setTimeout(() => {}, 350); } lastTap = currentTime;
        } else if (diffX < -80) { 
            if(db.configs.modo === 'pedido') { let pa = db.pedidosAtivos.find(x => x.idUnico === idItem); if(pa) { pa.riscado = !pa.riscado; salvarBanco(); renderizarLista(); } } else if (db.configs.modo === 'compras') { let pa = db.pedidosAtivos.find(x => x.idUnico === idItem); if(pa) { const ciclo = ['pedido', 'comprado', 'entregue']; let idx = ciclo.indexOf(pa.status); if(idx < ciclo.length - 1) { pa.status = ciclo[idx + 1]; pa.historico.push({ status: pa.status, data: new Date().toISOString() }); salvarBanco(); renderizarLista(); } } }
        } else if (diffX > 80) {
             if (db.configs.modo === 'compras') { let pa = db.pedidosAtivos.find(x => x.idUnico === idItem); if(pa) { const ciclo = ['pedido', 'comprado', 'entregue']; let idx = ciclo.indexOf(pa.status); if(idx > 0) { pa.status = ciclo[idx - 1]; pa.historico.push({ status: pa.status, data: new Date().toISOString() }); salvarBanco(); renderizarLista(); } } }
        }
    }

    function abrirModalPedirProduto(prodId) { const p = db.produtos.find(x => x.id === prodId); if(!p) return; document.getElementById('pedidoIdProduto').value = p.id; document.getElementById('pedidoTitulo').innerText = `Pedir: ${p.nome}`; document.getElementById('pedidoQtd').value = p.qtdPadrao; document.getElementById('pedidoUnidade').value = p.unidade; document.getElementById('modalFazerPedido').style.display = 'flex'; }
    function confirmarInclusaoPedido() { const pId = document.getElementById('pedidoIdProduto').value; const qtd = parseFloat(document.getElementById('pedidoQtd').value); if(!qtd || qtd <= 0) return alert("Insira uma quantidade válida."); const novoPedido = { idUnico: 'pa_' + Date.now(), produtoId: pId, qtd: qtd, status: 'pedido', riscado: false, historico: [{ status: 'pedido', data: new Date().toISOString() }] }; db.pedidosAtivos.push(novoPedido); salvarBanco(); fecharModal('modalFazerPedido'); renderizarLista(); }

    function abrirModalZap() {
        const selForn = document.getElementById('zapFornecedor'); selForn.innerHTML = '<option value="todos">-- Todos os Fornecedores --</option>'; db.fornecedores.forEach(f => selForn.innerHTML += `<option value="${f.id}">${f.nome}</option>`);
        const selColab = document.getElementById('zapColaborador'); selColab.innerHTML = ''; db.colaboradores.forEach(c => selColab.innerHTML += `<option value="${c.id}">${c.nome}</option>`);
        document.getElementById('modalZap').style.display = 'flex'; gerarTextoZap();
    }
    function gerarTextoZap() {
        const fornId = document.getElementById('zapFornecedor').value; const colabId = document.getElementById('zapColaborador').value; const res = db.restaurante; const colab = db.colaboradores.find(c => c.id === colabId) || { nome: "N/A", telefone: "N/A" }; const forn = db.fornecedores.find(f => f.id === fornId);
        let texto = `${res.nome}\nCNPJ: ${res.cnpj}\nContato: ${colab.nome}\nTelefone: ${colab.telefone}\nEnd.: ${res.endereco}\n${res.bairro} - ${res.cidade}\nPonto de referência: ${res.ponto}\n\n--------------------\n${forn ? forn.nome.toUpperCase() : 'FORNECEDOR DIVERSOS'}\n\nAqui embaixo, a lista dos itens que escolhi:\n\n`;
        let itensParaPedir = db.pedidosAtivos.filter(pa => pa.status === 'pedido' && !pa.riscado); let qtdItens = 0;
        itensParaPedir.forEach(pa => { const p = db.produtos.find(prod => prod.id === pa.produtoId); if(!p) return; if (fornId !== "todos" && !p.fornecedores.includes(fornId)) return; texto += `• ${p.nome} - Marca: ${p.marcasAprovadas || 'Qualquer'} - Qtd: ${pa.qtd} ${p.unidade}\n`; qtdItens++; });
        if (qtdItens === 0) { texto += "(Nenhum item pendente para este fornecedor)"; }
        document.getElementById('zapTexto').value = texto;
    }
    function copiarZap() { const txt = document.getElementById('zapTexto'); txt.select(); document.execCommand('copy'); alert("Lista copiada! Cole no WhatsApp do fornecedor."); }

    function abrirAdmin() { document.getElementById('inputSenhaAdmin').value = ''; document.getElementById('modalSenhaAdmin').style.display = 'flex'; setTimeout(() => document.getElementById('inputSenhaAdmin').focus(), 100); }
    document.getElementById('inputSenhaAdmin').addEventListener('input', function(e) { if(this.value === db.configs.senhaAdmin) { this.blur(); this.value = ''; fecharModal('modalSenhaAdmin'); document.getElementById('inputGoogleUrl').value = db.configs.url || ''; document.getElementById('modalPainelUnificado').style.display = 'flex'; } });
    function fecharModal(id) { document.getElementById(id).style.display = 'none'; }

    function abrirCadastroRestaurante() { fecharModal('modalPainelUnificado'); db.restaurante.nome = prompt("Nome do Restaurante:", db.restaurante.nome) || db.restaurante.nome; db.restaurante.cnpj = prompt("CNPJ:", db.restaurante.cnpj) || db.restaurante.cnpj; db.restaurante.endereco = prompt("Endereço:", db.restaurante.endereco) || db.restaurante.endereco; db.restaurante.bairro = prompt("Bairro:", db.restaurante.bairro) || db.restaurante.bairro; db.restaurante.cidade = prompt("Cidade:", db.restaurante.cidade) || db.restaurante.cidade; db.restaurante.ponto = prompt("Referência:", db.restaurante.ponto) || db.restaurante.ponto; salvarBanco(); alert("Dados salvos!"); }
    function abrirCadastroProduto() { fecharModal('modalPainelUnificado'); let nome = prompt("Nome do Novo Produto:"); if(!nome) return; let catText = db.categorias.map(c => c.nome).join(', '); let cat = prompt(`Categoria (Escolha uma: ${catText}):`); let unid = prompt("Unidade (Ex: kg, cx, pct, un):"); let qtd = parseFloat(prompt("Qtd Padrão de Pedido:", "1")); let preco = parseFloat(prompt("Preço Base Atual (R$):", "0.00")); let marcasOk = prompt("Marcas Aprovadas (Ex: Friboi, Seara):"); let marcasNok = prompt("Marcas Reprovadas:"); const novoId = 'p_' + Date.now(); db.produtos.push({ id: novoId, nome: nome, categoria: cat, marcasAprovadas: marcasOk, marcasReprovadas: marcasNok, historicoPrecos: [{ data: getHojeSTR(), preco: isNaN(preco) ? 0 : preco }], qtdPadrao: isNaN(qtd) ? 1 : qtd, unidade: unid || 'un', fornecedores: [] }); salvarBanco(); renderizarLista(); alert("Produto cadastrado!"); }
    function abrirCadastroColaborador() { fecharModal('modalPainelUnificado'); let nome = prompt("Nome do Colaborador:"); if(!nome) return; let tel = prompt("Telefone (Ex: 83 99999-9999):"); db.colaboradores.push({ id: 'c_' + Date.now(), nome: nome, telefone: tel || "", senha: "123" }); salvarBanco(); alert("Colaborador salvo!"); }
    function abrirCadastroFornecedor() { fecharModal('modalPainelUnificado'); let nome = prompt("Nome do Fornecedor:"); if(!nome) return; db.fornecedores.push({ id: 'f_' + Date.now(), nome: nome }); salvarBanco(); alert("Fornecedor salvo!"); }
</script>
